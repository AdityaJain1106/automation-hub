    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst rawJobs = items[0].json;\n\nconst jobArray = Array.isArray(rawJobs) ? rawJobs : [rawJobs];\n\nconst parsed = jobArray.map(job => ({\n  jobId: job.jobId || job.id || '',\n  title: job.title || job.positionName || '',\n  company: job.companyName || job.company || '',\n  location: job.location || '',\n  description: job.description || job.jobDescription || '',\n  applyUrl: job.jobUrl || job.applyUrl || '',\n  postedAt: job.postedAt || job.postedDate || ''\n})).filter(j => j.description && j.description.length > 100);\n\nreturn parsed.map(j => ({ json: j }));"
      },
      "id": "954a4e30-8c6d-40df-ba52-387b500fc740",
      "name": "Parse Apify Job Results",
